# Database (Docker Compose defaults)
DATABASE_URL="postgresql://murlon:murlon@localhost:5432/murlon"
DIRECT_URL="postgresql://murlon:murlon@localhost:5432/murlon"

# AI Provider: "openai-compatible" (default, for local LLM) or "anthropic"
AI_PROVIDER="openai-compatible"

# OpenAI Compatible (Ollama etc.)
OPENAI_API_BASE="http://localhost:11434/v1"
OPENAI_API_KEY=""
OPENAI_MODEL="gemma3"

# Anthropic (uncomment when AI_PROVIDER="anthropic")
# ANTHROPIC_API_KEY="your-anthropic-api-key"
# ANTHROPIC_MODEL="claude-sonnet-4-6"

# App
DENO_ENV="development"
